# ===========================================
# TrackSafe Link Backend — Railway + HiveMQ Cloud
# Environment Template
# ===========================================

# Server (Railway sets PORT automatically)
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Realtime Database
FIREBASE_DATABASE_URL=

# CORS (Optional — Flutter web / admin tools)
FRONTEND_URL=
ALLOWED_ORIGIN=

# ===========================================
# MQTT — HiveMQ Cloud (production)
# ===========================================
MQTT_ENABLED=true
MQTT_HOST=
MQTT_PORT=8883
MQTT_TLS=true
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=tracksafe-backend
MQTT_TOPIC_ROOT=tracksafe
MQTT_QOS=1

# Development — HiveMQ Public (tanpa auth):
# MQTT_HOST=broker.hivemq.com
# MQTT_PORT=1883
# MQTT_TLS=false
