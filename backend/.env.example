# Firebase Admin SDK (Firebase Console → Project Settings → Service Accounts)
# Wajib di-set juga di Vercel Dashboard → Settings → Environment Variables

FIREBASE_PROJECT_ID=tracksafe-link
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tracksafe-link.iam.gserviceaccount.com

# Paste private key sebagai SATU baris dengan \n (bukan newline nyata),
# atau biarkan multi-line di dalam tanda kutip ganda.
# Contoh Vercel-safe:
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

FIREBASE_DATABASE_URL=https://tracksafe-link-default-rtdb.asia-southeast1.firebasedatabase.app

# Local only
PORT=3000
NODE_ENV=development
