{
  "name": "tracksafe-backend",
  "version": "3.0.1",
  "private": true,
  "description": "TrackSafe Link — Express + Firebase + HiveMQ MQTT (ESP32 MQTT bridge)",
  "main": "server.js",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node test/api.test.js",
    "simulate:vercel": "node scripts/simulate-vercel.js",
    "simulate:gps": "node scripts/simulate-gps.js",
    "simulate:receiver": "node scripts/simulate-receiver.js",
    "simulate:devices": "node scripts/simulate-devices.js",
    "simulate:mqtt": "node scripts/simulate-mqtt.js",
    "mqtt": "node mqtt-worker.js",
    "vercel-dev": "vercel dev",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "mqtt": "^5.15.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
